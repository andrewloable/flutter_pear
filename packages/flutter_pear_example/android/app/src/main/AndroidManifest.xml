<manifest xmlns:android="http://schemas.android.com/apk/res/android">
    <!-- INTERNET is declared in flutter_pear_bare's library manifest and
         merges in automatically; not duplicated here. -->
    <!-- E7.2 QR scanner: CAMERA is a dangerous permission, requested at
         runtime by MainActivity's "flutter_pear_example/qr_scanner" channel;
         declaring it here is only what makes the runtime request legal.
         The uses-feature required=false below keeps this app installable on
         camera-less devices/emulators (manual-code fallback still works). -->
    <uses-permission android:name="android.permission.CAMERA"/>
    <uses-feature android:name="android.hardware.camera" android:required="false"/>
    <application
        android:label="flutter_pear_example"
        android:name="${applicationName}"
        android:icon="@mipmap/ic_launcher">
        <activity
            android:name=".MainActivity"
            android:exported="true"
            android:launchMode="singleTop"
            android:taskAffinity=""
            android:theme="@style/LaunchTheme"
            android:configChanges="orientation|keyboardHidden|keyboard|screenSize|smallestScreenSize|locale|layoutDirection|fontScale|screenLayout|density|uiMode"
            android:hardwareAccelerated="true"
            android:windowSoftInputMode="adjustResize">
            <!-- Specifies an Android theme to apply to this Activity as soon as
                 the Android process has started. This theme is visible to the user
                 while the Flutter UI initializes. After that, this theme continues
                 to determine the Window background behind the Flutter UI. -->
            <meta-data
              android:name="io.flutter.embedding.android.NormalTheme"
              android:resource="@style/NormalTheme"
              />
            <intent-filter>
                <action android:name="android.intent.action.MAIN"/>
                <category android:name="android.intent.category.LAUNCHER"/>
            </intent-filter>
        </activity>
        <!-- E7.2 QR scanner activity, launched via the modern Activity
             Result API from MainActivity's scanQrCode() method channel
             handler; never started from outside this app. -->
        <activity
            android:name=".QrScannerActivity"
            android:exported="false"
            android:theme="@style/LaunchTheme"
            android:screenOrientation="portrait" />
        <!-- DES-T1: exposes received files to whichever app the user picks
             from MainActivity's "flutter_pear_example/share_open" channel
             via a content:// URI, never a bare file:// path (unreadable by
             other apps on API 24+). Covers only the received-files subtree,
             see res/xml/file_paths.xml. -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
        <!-- Don't delete the meta-data below.
             This is used by the Flutter tool to generate GeneratedPluginRegistrant.java -->
        <meta-data
            android:name="flutterEmbedding"
            android:value="2" />
    </application>
    <!-- Required to query activities that can process text, see:
         https://developer.android.com/training/package-visibility and
         https://developer.android.com/reference/android/content/Intent#ACTION_PROCESS_TEXT.

         In particular, this is used by the Flutter engine in io.flutter.plugin.text.ProcessTextPlugin. -->
    <queries>
        <intent>
            <action android:name="android.intent.action.PROCESS_TEXT"/>
            <data android:mimeType="text/plain"/>
        </intent>
    </queries>
</manifest>
